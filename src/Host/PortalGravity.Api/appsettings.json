{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=portal_gravity;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "portal-gravity",
    "Audience": "portal-gravity-api",
    "Key": "CHANGE_THIS_TO_A_SECURE_256BIT_SECRET_KEY_IN_PRODUCTION",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
