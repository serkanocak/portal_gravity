{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=portal_gravity;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "portal-gravity",
    "Audience": "portal-gravity-api",
    "Key": "REPLACE_WITH_ACTUAL_SECRET_DO_NOT_COMMIT",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning"
    }
  }
}
